<?xml version="1.0" encoding="utf-8"?>

<Grid xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Locksley.ViewModels"
             x:Class="Locksley.Pages.Views.ScoreSheetListItemView"
             x:DataType="viewModels:ScoreSheetListItemViewModel"
             BackgroundColor="{Binding Selected, Converter={StaticResource SelectedConverter}, ConverterParameter={StaticResource Blue300Accent}}">

    
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Label Grid.Row="0" 
           Text="{Binding Title}" 
           FontAttributes="Bold" />

    <Label Grid.Row="1" 
           Text="{Binding Score}" />
</Grid>