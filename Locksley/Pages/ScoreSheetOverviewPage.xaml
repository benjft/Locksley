<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Locksley.ViewModels"
             x:Class="Locksley.Pages.ScoreSheetOverviewPage" 
             x:DataType="viewModels:ScoreSheetsOverviewViewModel">
    <ContentPage.Content>
        <ListView ItemsSource="{Binding ScoreSheets}">
            <ListView.ItemTemplate>
                <DataTemplate
                    x:DataType="viewModels:ScoreSheetViewModel">
                    <ViewCell>
                        <Grid Padding="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" 
                                   Text="{Binding Title}" 
                                   FontAttributes="Bold" />

                            <Label Grid.Row="1" 
                                   Text="{Binding Score}" />
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </ContentPage.Content>
</ContentPage>