<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Locksley.ViewModels"
             xmlns:views="clr-namespace:Locksley.Pages.Views"
             x:Class="Locksley.Pages.ScoreSheetOverviewPage" 
             x:DataType="viewModels:ScoreSheetsOverviewViewModel">
    <ContentPage.Content>
        <CollectionView
                  SelectionMode="Multiple"
                  ItemsSource="{Binding ScoreSheets}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:ScoreSheetListItemViewModel">
                    <views:ScoreSheetListItemView />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </ContentPage.Content>
</ContentPage>